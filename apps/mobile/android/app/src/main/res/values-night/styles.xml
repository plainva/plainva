<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Night (dark) system-bar icon color: LIGHT icons on the dark bars,
         mirroring the day styles in values/styles.xml (package B, 2026-07-24).
         A style qualified for -night fully REPLACES its default, so every item
         is repeated here. A runtime StatusBar.setStyle from the resolved app
         theme still overrides this at launch. -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
