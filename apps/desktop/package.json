{
  "name": "desktop",
  "private": true,
  "version": "0.4.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:isolated": "vite --port 1440 --strictPort",
    "tauri:isolated": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:prod": "playwright test --config playwright.prod.config.ts",
    "smoke:prod": "pnpm build && pnpm test:e2e:prod",
    "test:native": "wdio run ./wdio.conf.ts"
  },
  "dependencies": {
