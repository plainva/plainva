    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@uiw/codemirror-extensions-basic-setup": "^4.25.11",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "d3-quadtree": "^3.0.1",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.12",
    "i18next": "^26.3.6",
    "katex": "^0.17.0",
    "lucide": "^1.24.0",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
